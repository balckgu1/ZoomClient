api_key:
  deepseek: "sk-1aXXX"
  openai: "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  qwen: "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

subagent:
  defaultMaxTurns: 5
  defaultSystemPrompt : "You are a focused subagent running inside an isolated context. Use the provided tools to complete the user's subtask, then return ONE concise summary (a single sentence or short paragraph) as your final answer. Do NOT paste tool call transcripts into the final answer; only return the essential result that the parent agent needs."
  forkSubtaskPromptPrefix: "<subagent-fork> Focus ONLY on the following subtask based on the prior context. Complete it using the provided tools, then return ONE concise summary as your final answer. Subtask: "

skills:
  dir: "./.skills"

compact:
  persistThreshold:      4000
  previewBytes:          1000
  keepRecentToolResults: 4
  contextLimit:          60000
  persistDir:            ".task_outputs/tool-results"

agentloop:
  maxTurns: 25 # 默认最大轮数
  todoRoundsThreshold: 9 # 默认待办轮数阈值
  maxTools: 5 # 默认每轮可调用最大工具数
  sensitiveFiles: [".env", "id_rsa"]


# 模式说明：
#   default 未命中规则时问用户
#   plan    只允许读，任何写/执行类工具都拒绝
#   auto    只读工具自动放行，写/执行类工具问用户
permission:
  mode: "auto"
  interactive: true   # 命中 ask 时是否从 stdin 询问；CI / 非交互场景请改为 false
  denyRules:
    - tool: "run_bash"
      content: "sudo "
    - tool: "run_bash"
      content: "rm -rf /"
    - tool: "run_bash"
      content: "rm -rf /*"
    - tool: "run_bash"
      content: "mkfs"
    - tool: "run_bash"
      content: "shutdown"
    - tool: "run_bash"
      content: "reboot"
    - tool: "run_bash"
      content: "> /dev/sda"
    - tool: "run_bash"
      content: ":(){:|:&};:"
  allowRules:
    - tool: "run_bash"
      content: "git status"
    - tool: "run_bash"
      content: "git diff"