api_key:
  anthropic: "sk-ant-api03-xxx"
  gemini: "AIzaSyXXX"

# openai client config
# example
# # DeepSeek
# openai:
#   api_key: "sk-xxx"
#   base_url: "https://api.deepseek.com"
#   model_name: "deepseek-v4-flash"

# # Kimi
