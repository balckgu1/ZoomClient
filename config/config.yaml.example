# openai client config
# example
# # DeepSeek
# openai:
#   api_key: "sk-xxx"
#   base_url: "https://api.deepseek.com"
#   model_name: "deepseek-v4-flash"

# # Kimi
# openai:
#   api_key: "sk-xxx"
#   base_url: "https://api.moonshot.cn"
#   model_name: "moonshot-v1-8k"

# # Qwen
# openai:
#   api_key: "sk-xxx"
#   base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
#   model_name: "qwen-plus"

# # OpenAI
# openai:
#   api_key: "sk-xxx"
#   base_url: "https://api.openai.com"
#   model_name: "gpt-4o"
openai:
  api_key: "sk-xxx"
  base_url: "https://api.deepseek.com"
  model_name: "deepseek-v4-flash"

ollama:
	base_url: "http://127.0.0.1:11434"
  model_name: "modelscope.cn/Qwen/Qwen3-8B-GGUF:latest"

anthropic:
  api_key: "sk-ant-api03-xxx"
  model_name: "claude-opus-4-8"

gemini:
  api_key: "AIzaSyXXX"
  model_name : "gemini-3.5-flash"

# subagent config
subagent:
  defaultMaxTurns: 10
  defaultSystemPrompt : "You are a focused subagent running inside an isolated context. Use the provided tools to complete the user's subtask, then return ONE concise summary (a single sentence or short paragraph) as your final answer. Do NOT paste tool call transcripts into the final answer; only return the essential result that the parent agent needs."
  forkSubtaskPromptPrefix: "<subagent-fork> Focus ONLY on the following subtask based on the prior context. Complete it using the provided tools, then return ONE concise summary as your final answer. Subtask: "

# tool config
tools:
  defaultBashTimeout: 120  # default timeout in seconds

# skill config
skills:
  dir: "./.skills"  # skill directory

# memory config
memory:
  dir: "./.memory"  # memory directory

# session config
session:
  dir: "./.sessions"  # session history directory

# compact system config
compact:
  persistThreshold:      4000  # persist threshold
  previewBytes:          1000  # preview bytes
  keepRecentToolResults: 4     # keep recent tool results
  contextLimit:          60000 # context limit
  persistDir:            ".task_outputs/tool-results"  # persist directory

# agentloop config
agentloop:
  maxTurns: 25 # Default maximum number of rounds
  todoRoundsThreshold: 9 # Default Todo Round Threshold
  maxTools: 5 # Default maximum number of tools that can be called per round
  sensitiveFiles: [".env", "id_rsa"] # Sensitive file list


#Mode description:
#Ask the user when the default rule is not hit
#The plan only allows reading, and any write/execute tools are rejected
#Auto read-only tool automatically releases, write/execute tools ask users
permission:
  mode: "auto"
  interactive: true   # Whether to query from STDIN when hitting ask; Please change CI/non interactive scenario to false
  denyRules:
    - tool: "run_bash"
      content: "sudo "
    - tool: "run_bash"
      content: "rm -rf /"
    - tool: "run_bash"
      content: "rm -rf /*"
    - tool: "run_bash"
      content: "mkfs"
    - tool: "run_bash"
      content: "shutdown"
    - tool: "run_bash"
      content: "reboot"
    - tool: "run_bash"
      content: "> /dev/sda"
    - tool: "run_bash"
      content: ":(){:|:&};:"
  allowRules:
    - tool: "run_bash"
      content: "git status"
    - tool: "run_bash"
      content: "git diff"